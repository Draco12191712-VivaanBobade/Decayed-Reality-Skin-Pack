###############################################################################
# Minecraft Bedrock Skin Pack - .gitattributes
###############################################################################

# Auto-detect text files and normalize to LF
* text=auto eol=lf

###############################################################################
# Source Files
###############################################################################

*.json      text eol=lf
*.lang      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.license   text eol=lf

###############################################################################
# Images (Binary)
###############################################################################

*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary

###############################################################################
# Archives
###############################################################################

*.zip       binary
*.mcpack    binary
*.mcaddon   binary

###############################################################################
# Minecraft Files
###############################################################################

manifest.json text eol=lf
skins.json    text eol=lf

###############################################################################
# macOS
###############################################################################

.DS_Store export-ignore

###############################################################################
# Documentation
###############################################################################

README.md   text eol=lf
LICENSE     text eol=lf
CREDITS.md  text eol=lf

###############################################################################
# GitHub
###############################################################################

*.json linguist-language=JavaScript
.github/** text eol=lf